{
    "name": "sayuprc/result-type",
    "description": "Library for handling result types in PHP",
    "type": "library",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.1",
        "symplify/easy-coding-standard": "^13.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "ResultType\\": "src/"
        }
    },
    "authors": [
        {
            "name": "sayuprc"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.4"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=-1 --no-progress",
        "phpstan-clear-cache": "phpstan clear-result-cache",
        "ecs": "ecs check --ansi --no-progress-bar",
        "ecs-fix": "ecs check --fix --ansi --no-progress-bar"
    }
}
